  "version": "0.1.0",
  "identifier": "com.google-chat-wrapper.app",
  "build": {
    "frontendDist": "./src-frontend",
    "devUrl": "https://chat.google.com"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
